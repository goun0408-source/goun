# ══════════════════════════════════════════════════════
# ScalpGuard — .gitignore
# ══════════════════════════════════════════════════════

# ── Python 캐시 / 빌드 ───────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.Python
*.so

# ── 가상환경 ─────────────────────────────────────────
.venv/
venv/
env/
.env

# ── 합성 데이터 (코드로 재생성 가능, 용량 큼) ────────
*.csv
ticket_data.csv

# ── 신고 DB (서버에서 매 재시작 시 초기화됨) ─────────
reports.db

# ── 학습 결과 그래프 ───────────────────
# 모델 분석 페이지에서 표시하므로 배포에 포함 (제외하지 않음)
# results/

# ── OS 임시 파일 ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE 설정 ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── 로그 ─────────────────────────────────────────────
*.log

# ── Claude Code 로컬 설정 ────────────────────────────
.claude/

# ── 테스트/임시 스크린샷 ─────────────────────────────
shot_*.png
chk_*.png
sb_*.png
fix_*.png
pw_*.py

# ── Jupyter ──────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Streamlit 로컬 캐시 ──────────────────────────────
.streamlit/secrets.toml

# ══════════════════════════════════════════════════════
# 배포에 반드시 포함해야 할 파일 (명시적 주석)
# ══════════════════════════════════════════════════════
# !model.pth       ← PyTorch 모델 가중치 (배포 필수)
# !scaler.pkl      ← StandardScaler (배포 필수)
# !app.py          ← Streamlit 앱 진입점
# !requirements.txt
# !README.md
